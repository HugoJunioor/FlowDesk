{
  "name": "flowdesk-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "FlowDesk — sistema de gestao de demandas (monorepo: apps/web + apps/api)",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @flowdesk/web",
    "dev:api": "npm run dev -w @flowdesk/api",
    "dev:web": "npm run dev -w @flowdesk/web",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @flowdesk/web",
    "build:api": "npm run build -w @flowdesk/api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "validate": "npm run validate --workspaces --if-present",
    "test:coverage": "npm run test:coverage -w @flowdesk/web",
    "build-storybook": "npm run build-storybook -w @flowdesk/web",
    "preflight": "npm run preflight -w @flowdesk/web",
    "preview": "npm run preview -w @flowdesk/web",
    "prepare": "husky",
    "backup": "node scripts/backup.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5"
  }
}
