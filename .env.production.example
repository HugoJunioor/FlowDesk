# ════════════════════════════════════════════════════════════════════
# FlowDesk — variaveis de PRODUCAO (raiz do projeto)
# Copie pra `.env` no servidor on-prem. NAO commite o arquivo real.
# Geradores em docs/PROD_ENV_CHECKLIST.md.
# ════════════════════════════════════════════════════════════════════

# ─── Traefik / Dominio ──────────────────────────────────────────────
# Dominio publico — sera usado pelo Traefik pra rotear e gerar SSL.
DOMAIN=flow.just.cloud

# Email pra Let's Encrypt notificar expiracao (recebe avisos de certificado).
LETSENCRYPT_EMAIL=admin@just.cloud

# ─── Acesso restrito a VPN ──────────────────────────────────────────
# Lista CSV de IPs autorizados a acessar o sistema.
# Aplicado em DUAS camadas:
#   1. UFW (firewall do servidor) — bloqueia no kernel
#   2. Traefik IP whitelist middleware — bloqueia mesmo se UFW cair
#
# Para CIDR: <IP-VPN-1>/32
# Para multiplos IPs: <IP-VPN-1>/32,<IP-VPN-2>/32
VPN_IPS=<IP-VPN-1>/32,<IP-VPN-2>/32

# ─── Postgres ───────────────────────────────────────────────────────
# Gere com: openssl rand -base64 24 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=

# ─── Slack ──────────────────────────────────────────────────────────
# Bot token (xoxb-...) — usado por sync + composer + webhook
SLACK_BOT_TOKEN=

# Workspace (slug — ex: wearejust-it)
SLACK_WORKSPACE=

# User OAuth (postar como usuario real)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://flow.just.cloud/auth/slack/callback

# Signing secret pro webhook Events API (em https://api.slack.com/apps -> Basic Info)
SLACK_SIGNING_SECRET=

# Equipe interna (qualquer membro nesta lista eh atendente; resto eh cliente)
# Substitua pelos nomes reais do seu time no deploy — NAO comite a versao
# preenchida (use override em .env.production, gitignored).
TEAM_EMAIL_DOMAINS=["empresa.com"]
TEAM_MEMBERS=["Nome Operador 1","Nome Operador 2"]

# ─── CORS / cookies (preenchidos automaticamente pelo compose) ──────
# ALLOWED_ORIGINS, COOKIE_DOMAIN, COOKIE_SECURE — nao precisa setar aqui.
