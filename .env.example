# FlowDesk - Environment Variables
# Copy this file to .env and fill in the values

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_WORKSPACE=your-workspace-name

# Equipe interna (separar por virgula dentro do array JSON).
# Usuarios do Slack cujo real_name ou display_name esteja nesta lista
# sao tratados como membros da equipe (respostas deles contam como
# "primeiro atendimento"). Todos os demais sao clientes externos.
# TEAM_MEMBERS=["Fulano da Silva","Ciclano dos Santos"]
TEAM_MEMBERS=[]

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=justflow
DB_USER=postgres
DB_PASSWORD=your-db-password
