# FlowDesk - Environment Variables
# Copy this file to .env and fill in the values

# === Modo Demo (portfolio Vercel) ===
# Quando "true": usa dados ficticios + banner com credenciais visiveis.
# Em producao real, deixar vazio ou remover.
VITE_DEMO_MODE=

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_WORKSPACE=your-workspace-name

# === Slack User OAuth (postar como cada usuario) ===
# Pegue em api.slack.com/apps -> seu app -> Basic Information -> App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# URL de callback do OAuth (precisa estar registrada no Slack)
SLACK_REDIRECT_URI=http://localhost:8080/auth/slack/callback

# === Identificacao de equipe interna ===
# REGRA PRIMARIA: dominios de email corporativo.
# Qualquer usuario do Slack com email terminando em um desses dominios
# eh tratado como equipe interna (respostas dele contam como atendimento).
# Auto-atualiza pra novos funcionarios sem precisar editar config.
TEAM_EMAIL_DOMAINS=["wearejust.it"]

# REGRA SECUNDARIA (fallback): lista manual de nomes.
# So usar pra usuarios sem email exposto no Slack (caso raro — invitados
# via SSO sem perfil completo). Em geral pode deixar vazio.
# TEAM_MEMBERS=["Fulano da Silva","Ciclano dos Santos"]
TEAM_MEMBERS=[]

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=justflow
DB_USER=postgres
DB_PASSWORD=your-db-password
