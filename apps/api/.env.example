# FlowDesk API — exemplo de configuração
# Copie para .env e ajuste os valores

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL=postgresql://flowdesk:flowdesk@localhost:5432/flowdesk
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Auth
JWT_SECRET=mude-isto-em-producao-minimo-32-chars-aleatorios
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS — csv de origens permitidas em produção
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate limiting
RATE_LIMIT_AUTH=10
RATE_LIMIT_WRITE=60
RATE_LIMIT_READ=300

# Slack (mantido pra fase de port das demandas)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
