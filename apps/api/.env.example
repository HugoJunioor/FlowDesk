# FlowDesk API — exemplo de configuração
# Copie para .env e ajuste os valores

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL=postgresql://flowdesk:flowdesk@localhost:5432/flowdesk
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Auth
JWT_SECRET=mude-isto-em-producao-minimo-32-chars-aleatorios
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS — csv de origens permitidas em produção
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate limiting
RATE_LIMIT_AUTH=10
RATE_LIMIT_WRITE=60
RATE_LIMIT_READ=300

# Slack (mantido pra fase de port das demandas)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# Sentry — opcional. Sem DSN, observability fica desligado (zero overhead).
# Criar projeto em https://sentry.io e colar a DSN aqui.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# Cron de SLA reminders (server-side). Em prod recomenda-se ativar.
SLA_CRON_ENABLED=false
SLA_CRON_INTERVAL_SECONDS=300
