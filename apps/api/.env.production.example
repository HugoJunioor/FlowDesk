# ════════════════════════════════════════════════════════════════════
# FlowDesk API — PRODUCAO
# Copie pra `apps/api/.env` no servidor. NAO commite.
# ════════════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ─── Database (Postgres no container 'postgres' da rede Docker) ─────
# A senha deve ser igual a POSTGRES_PASSWORD do .env raiz.
DATABASE_URL=postgresql://flowdesk:CHANGE_ME@postgres:5432/flowdesk
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Auth / JWT ─────────────────────────────────────────────────────
# Gere: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Setados pelo docker-compose a partir de DOMAIN/Traefik:
# COOKIE_SECURE=true
# COOKIE_DOMAIN=flow.just.cloud
# ALLOWED_ORIGINS=https://flow.just.cloud

# ─── Rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_AUTH=10
RATE_LIMIT_WRITE=60
RATE_LIMIT_READ=300

# ─── Crons ──────────────────────────────────────────────────────────
SLA_CRON_ENABLED=true
SLA_CRON_INTERVAL_SECONDS=300

# Lembrete diario por email (9h dias uteis). Precisa SMTP_* abaixo.
DAILY_REMINDER_ENABLED=false
APP_BASE_URL=https://flow.just.cloud

# ─── SMTP (opcional — pra lembrete diario) ─────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=FlowDesk <noreply@just.cloud>

# ─── Telegram (opcional) ────────────────────────────────────────────
# Crie bot em @BotFather, depois configure webhook (docs/api/docs/TELEGRAM.md)
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=FlowDeskJustBot
# TELEGRAM_WEBHOOK_SECRET=

# ─── Slack webhook (Events API) ─────────────────────────────────────
# Sem isto, sync continua via polling 5min do scripts/syncSlack.cjs.
# SLACK_WEBHOOK_ENABLED=true
# SLACK_SIGNING_SECRET=

# ─── Sentry (opcional) ──────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# ─── OpenAPI ────────────────────────────────────────────────────────
# Desabilita Swagger UI em prod (recomendado)
OPENAPI_ENABLED=false

# ─── Build info (CI injeta automaticamente) ─────────────────────────
# BUILD_SHA=
# BUILD_DATE=
